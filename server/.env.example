MONGODB_URI=mongodb://localhost:27017/AuraPC
PORT=3000
JWT_SECRET=your-jwt-secret-change-me

# Gmail SMTP - dùng App Password (không dùng mật khẩu đăng nhập)
# Tạo App Password: Google Account > Security > 2-Step Verification > App passwords
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-16-char-app-password

# URL frontend — MUST match payment return hosts (same origin as checkout pages).
# Production: use your canonical domain, e.g. https://www.aurapc.io.vn (not a stale *.vercel.app project).
FRONTEND_URL=http://localhost:4200
# URL admin panel (nếu deploy riêng, thêm vào CORS)
ADMIN_URL=https://aura-pc-admin.vercel.app
# Dev only; production must use a public webhook URL or leave unset (AuraVisual disabled on prod).
AURA_VISUAL_WEBHOOK_URL=http://localhost:5678/webhook/auravisual-trigger
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_HUB_BUCKET=hub-images
SUPABASE_AVATAR_BUCKET=hub-images

# Admin seed secret - dùng 1 lần để tạo admin đầu tiên qua POST /api/admin/auth/seed
ADMIN_SEED_SECRET=change-me-to-a-random-string

# MoMo Payment
# ── Local máy: MoMo sandbox THẬT → MOMO_MOCK_MODE=false + credential từ M4B; xem server/docs/MOMO_LOCAL.md
# ── Render/Vercel demo: MOMO_MOCK_MODE=true (không cần merchant; không gọi API MoMo)
# Use your own sandbox credentials from MoMo M4B / Business Test Tool.
# Legacy public sample credentials often fail with resultCode 11007.
MOMO_PARTNER_CODE=your-momo-partner-code
MOMO_ACCESS_KEY=your-momo-access-key
MOMO_SECRET_KEY=your-momo-secret-key
# Sandbox: https://test-payment.momo.vn/v2/gateway/api/create
# Production: https://payment.momo.vn/v2/gateway/api/create
MOMO_ENDPOINT=https://test-payment.momo.vn/v2/gateway/api/create
# Same host as FRONTEND_URL + path /checkout-momo-return (whitelist this URL in MoMo when not using mock).
# Local: http://localhost:4200/checkout-momo-return
# Production: https://www.aurapc.io.vn/checkout-momo-return (example — use your canonical domain)
MOMO_REDIRECT_URL=http://localhost:4200/checkout-momo-return
# MOMO_IPN_URL = your backend HTTPS URL (Render in production)
# Local real MoMo: dùng ngrok → https://xxx.ngrok-free.app/api/payment/momo/ipn (MoMo không gọi được localhost)
# Production: https://your-backend.onrender.com/api/payment/momo/ipn
MOMO_IPN_URL=https://your-ngrok-url.ngrok-free.app/api/payment/momo/ipn
MOMO_PARTNER_NAME=AuraPC
MOMO_STORE_ID=AuraPC-Local
# true = mock (khuyến nghị trên deploy không có merchant). false = gọi API MoMo (local sandbox).
MOMO_MOCK_MODE=true

# ZaloPay Payment
# Default sandbox test credentials (app 2554) from zalopay-samples/test-apps.
# For production, replace with your merchant credentials from mc.zalopay.vn.
ZALOPAY_APP_ID=2554
ZALOPAY_KEY1=sdngKKJmqEMzvh5QQcdD2A9XBSKUNaYn
ZALOPAY_KEY2=trMrHtvjo6myautxDUiAcYsVtaeQ8nhf
# Sandbox: https://sb-openapi.zalopay.vn/v2/create
# Production: https://openapi.zalopay.vn/v2/create
ZALOPAY_ENDPOINT=https://sb-openapi.zalopay.vn/v2/create
# Sandbox: https://sb-openapi.zalopay.vn/v2/query
# Production: https://openapi.zalopay.vn/v2/query
ZALOPAY_QUERY_ENDPOINT=https://sb-openapi.zalopay.vn/v2/query
# Same host as FRONTEND_URL + path /checkout-zalopay-return
# Production: https://www.aurapc.io.vn/checkout-zalopay-return (example)
ZALOPAY_REDIRECT_URL=http://localhost:4200/checkout-zalopay-return
# ZALOPAY_CALLBACK_URL = your backend HTTPS URL (Render in production)
# Local: use ngrok → https://xxx.ngrok-free.app/api/payment/zalopay/callback
# Production: https://your-backend.onrender.com/api/payment/zalopay/callback
ZALOPAY_CALLBACK_URL=https://your-ngrok-url.ngrok-free.app/api/payment/zalopay/callback
